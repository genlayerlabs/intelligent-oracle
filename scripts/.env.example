# RPC endpoint URL for the GenLayer network.
# Defaults to the chain config (studionet -> https://studio.genlayer.com/api) when unset.
# Override for localnet or testnets, e.g. http://localhost:4000/api
RPC_URL=https://studio.genlayer.com/api

# Optional: signing private key (0x-prefixed). If unset, a fresh ephemeral
# account is created on each run, which is fine for studio.genlayer.com but
# not for testnets where you need a funded address.
# PRIVATE_KEY=0x...
